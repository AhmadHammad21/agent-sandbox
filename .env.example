# --- LLM (OpenRouter: one API for many models) ---
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Model the agent runs with (OpenRouter slug). Defaults are cheap models to
# avoid surprise bills; upgrade for harder work, e.g.
#   anthropic/claude-sonnet-4.6, openai/gpt-4.1, google/gemini-2.5-pro
AGENT_MODEL=anthropic/claude-haiku-4.5
# Even cheaper model used for conversation summaries
SUMMARY_MODEL=google/gemini-2.5-flash-lite
# Optional attribution headers OpenRouter uses for rankings
OPENROUTER_APP_URL=https://github.com/agent-sandbox
OPENROUTER_APP_NAME=agent-sandbox

# --- Embeddings (separate from OpenRouter, which is chat-only) ---
# 'local' (default, dependency-free, dev-only) or 'voyage'
EMBEDDING_PROVIDER=local
# Embedding model when EMBEDDING_PROVIDER=voyage (must match schema dims)
EMBEDDING_MODEL=voyage-3
VOYAGE_API_KEY=

# --- Postgres ---
# A single instance; one schema per tenant.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/agent_sandbox

# --- Daytona (self-hosted sandbox runtime) ---
DAYTONA_API_URL=http://localhost:3986
DAYTONA_API_KEY=

# --- S3 / MinIO (object storage) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=agent-sandbox
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
# MinIO and other S3-compatible stores need path-style addressing
S3_FORCE_PATH_STYLE=true

# --- API ---
PORT=8080
# Comma-separated list of accepted tenant API keys is loaded from DB; this is
# only a fallback master key for admin/provisioning routes.
ADMIN_API_KEY=change-me
